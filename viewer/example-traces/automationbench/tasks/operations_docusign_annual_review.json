                "title": "Review Policies",
                "rows": [
                  {
                    "row_id": 2,
                    "cells": {
                      "Rule": "Deferred Reviews",
                      "Policy": "Departments with 'deferred' or 'restructuring' in Notes must not have review cycles initiated until the restructuring is complete. These holds are set by the executive team."
                    }
                  },
                  {
                    "row_id": 3,
                    "cells": {
                      "Rule": "Duplicate Entry Exclusion",
                      "Policy": "Rows with 'duplicate' in Notes are data entry errors and must be skipped entirely. Do not initiate review cycles for duplicate entries."
                    }
                  }
                ]
              },
              {
                "id": "ws_review_policies_q1",
                "title": "Q1 2026 Review Policy Updates",
                "rows": [
                  {
                    "row_id": 2,
                    "cells": {
                      "Rule": "Status Override via HR Email",
                      "Policy": "If HR has sent an email confirming a department's review readiness, the email confirmation supersedes the spreadsheet Review Status field. Departments confirmed as ready via HR email should be treated as Pending regardless of sheet status."
                    }
                  },
                  {
                    "row_id": 3,
                    "cells": {
                      "Rule": "Department Merger Exclusion",
                      "Policy": "Departments that HR has confirmed are being merged into another department via email must not have review cycles initiated. The absorbing department will handle reviews for merged staff."
                    }
                  },
                  {
                    "row_id": 4,
                    "cells": {
                      "Rule": "Compliance Audit Informational",
                      "Policy": "Departments undergoing a compliance audit mentioned in HR email may proceed with review cycles unless the email explicitly states the review must be delayed. Audits are informational only and do not block reviews."
                    }
                  }
                ]
              },
              {
                "id": "ws_review_eligibility_q1",
                "title": "Q1 2026 Review Eligibility Criteria",
                "rows": [
                  {
                    "row_id": 2,
                    "cells": {
                      "Rule": "Minimum Headcount Threshold",
                      "Criteria": "Departments must have a headcount of 100 or more to participate in the annual review cycle. Departments below this threshold should use the simplified quarterly review process instead."
                    }
                  },
                  {
                    "row_id": 3,
                    "cells": {
                      "Rule": "EXEMPT Flag Exclusion",
                      "Criteria": "Departments with 'EXEMPT' in their Notes field are pending executive override approval and must NOT have review cycles initiated until the override is formally approved. This applies regardless of other eligibility criteria."
                    }
                  },
                  {
                    "row_id": 4,
                    "cells": {
                      "Rule": "Active Investigation Exclusion",
                      "Criteria": "Departments flagged as having an active compliance investigation (via Notes or confirmed by COO email) must not have review cycles initiated until the investigation is closed. This is distinct from routine compliance audits which are informational only."
                    }
                  },
                  {
                    "row_id": 5,
                    "cells": {
                      "Rule": "Headcount Override via COO Email",
                      "Criteria": "If the COO has sent an email with updated headcount figures for a department, the email figure supersedes the spreadsheet value for eligibility evaluation purposes."
                    }
                  }
                ]
              }
