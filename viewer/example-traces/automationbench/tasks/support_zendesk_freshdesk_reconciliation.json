            "worksheets": [
              {
                "id": "ws_mapping",
                "title": "Sync Rules",
                "headers": [
                  "Rule",
                  "Condition",
                  "Action"
                ],
                "rows": [
                  {
                    "row_id": 2,
                    "cells": {
                      "Rule": "Match Criteria",
                      "Condition": "Tickets match by subject (exact) and requester email",
                      "Action": "Mark as matched pair. Check for discrepancies."
                    }
                  },
                  {
                    "row_id": 3,
                    "cells": {
                      "Rule": "Missing Counterpart",
                      "Condition": "Ticket exists in one platform but not the other",
                      "Action": "Create counterpart ticket in the other platform with same subject, description, and priority."
                    }
                  },
                  {
                    "row_id": 4,
                    "cells": {
                      "Rule": "Skip Closed/Resolved",
                      "Condition": "An UNMATCHED ticket (exists in only one platform) has status closed or resolved (Zendesk: 'closed' or 'solved'; Freshdesk: status 4=resolved or 5=closed). Do NOT create counterparts for unmatched closed/resolved tickets. NOTE: This rule does NOT apply to matched pairs -- if a matched pair has one resolved and one open ticket, that IS a status discrepancy and must be logged under the Discrepancy Handling rule.",
                      "Action": "For unmatched closed/resolved tickets: skip entirely. Do not create counterpart. For matched pairs where one side is resolved and the other is open: treat as a status discrepancy -- log to ws_discrepancies and add notes to both tickets."
                    }
                  },
                  {
                    "row_id": 5,
                    "cells": {
                      "Rule": "Exclude Internal",
                      "Condition": "Requester email domain contains 'internal.company.com'",
                      "Action": "Skip reconciliation entirely."
                    }
                  },
                  {
                    "row_id": 6,
                    "cells": {
                      "Rule": "Discrepancy Handling",
                      "Condition": "Matched tickets have different status or priority",
                      "Action": "Log discrepancy to ws_discrepancies sheet. Add internal note to both tickets."
                    }
                  },
                  {
                    "row_id": 7,
                    "cells": {
                      "Rule": "Priority Equivalence",
                      "Condition": "Zendesk uses string priorities: low, normal, high, urgent. Freshdesk uses integers: 1=low, 2=medium, 3=high, 4=urgent. The equivalence mapping is: ZD low = FD 1, ZD normal = FD 2, ZD high = FD 3, ZD urgent = FD 4.",
                      "Action": "Use this mapping when comparing priorities between platforms. Only flag as a discrepancy if the mapped values differ."
                    }
                  }
                ]
              },
