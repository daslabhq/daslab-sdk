                "rows": [
                  {
                    "row_id": 2,
                    "cells": {
                      "Rule": "Duplicate Handling",
                      "Policy": "Emergencies with 'Duplicate' in Notes have already been dispatched and must not receive additional notifications or tracking. Skip these entries entirely."
                    }
                  },
                  {
                    "row_id": 3,
                    "cells": {
                      "Rule": "Category Filter",
                      "Policy": "Only respond to emergencies matching the requested category. IT emergencies have a separate response workflow."
                    }
                  },
                  {
                    "row_id": 4,
                    "cells": {
                      "Rule": "False Alarm Exclusion",
                      "Policy": "Emergencies with 'false alarm' in Notes have been investigated and confirmed as non-events. Do not dispatch notifications or create tracking items for these entries."
                    }
                  },
                  {
                    "row_id": 5,
                    "cells": {
                      "Rule": "Location Requirement",
                      "Policy": "All emergency notifications (SMS, email) must include the specific location of the incident."
                    }
                  },
                  {
                    "row_id": 6,
                    "cells": {
                      "Rule": "Hold Exclusion",
                      "Policy": "Emergencies with 'HOLD' in Notes are awaiting external clearance and must not be dispatched until the hold is lifted."
                    }
                  },
                  {
                    "row_id": 7,
                    "cells": {
                      "Rule": "Unverified Sensor Exclusion",
                      "Policy": "Emergencies with 'awaiting verification' or 'unconfirmed' in Notes indicate the triggering sensor has not been validated. These must not be dispatched until verification is complete."
                    }
                  }
                ]
              },
