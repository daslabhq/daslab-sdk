                "id": "ws_protocols_q1_update",
                "title": "Q1 2026 Protocol Updates",
                "rows": [
                  {
                    "row_id": 2,
                    "cells": {
                      "Rule": "Priority Override via Safety Team Email",
                      "Policy": "If the safety team has sent an email reclassifying the priority of an emergency, the email classification supersedes the spreadsheet Priority field. Check safety team emails before using the Priority column value."
                    }
                  },
                  {
                    "row_id": 3,
                    "cells": {
                      "Rule": "Contained Incident Exclusion",
                      "Policy": "Emergencies that the safety team has confirmed as fully contained and cordoned off via email must not be dispatched. The containment email takes precedence over the spreadsheet Status field."
                    }
                  },
                  {
                    "row_id": 4,
                    "cells": {
                      "Rule": "Stale Emergency Window",
                      "Policy": "Emergencies reported more than 12 hours before the current time (2026-01-29T14:00:00Z) are considered stale and must not be dispatched. These have already been handled by the previous shift."
                    }
                  },
                  {
                    "row_id": 5,
                    "cells": {
                      "Rule": "Remaining Count Requirement",
                      "Policy": "All SMS notifications must include the total count of remaining actionable new Facilities emergencies (after applying all exclusion rules). This helps the on-call team understand workload."
                    }
                  },
                  {
                    "row_id": 6,
                    "cells": {
                      "Rule": "Scheduled Drill Exclusion",
                      "Policy": "If the safety team has sent an email confirming an emergency was actually a scheduled drill or test, that incident must not be dispatched. The drill confirmation email takes precedence over spreadsheet data."
                    }
                  },
                  {
                    "row_id": 7,
                    "cells": {
                      "Rule": "Incident Reference Code",
                      "Policy": "All emergency notifications (SMS, Monday board item, Notion page, email) must include an incident reference code in the format EMG-[row_id] where row_id is from the spreadsheet. Example: row_id 5 becomes EMG-5."
                    }
                  }
                ]
              }
