                    "row_id": 2,
                    "cells": {
                      "Policy": "Recently onboarded",
                      "Condition": "Earliest event of ANY type within 7 days",
                      "Action": "Exclude entirely: no tag, no email, no SF task",
                      "Notes": "Protects new customers from premature alerts"
