                  },
                  {
                    "row_id": 5,
                    "cells": {
                      "Rule": "Tag assignment",
                      "Condition": "Each non-excluded customer",
                      "Action": "Tag as low-usage, normal-usage, or high-usage",
                      "Notes": "Based on feature_use count vs thresholds"
                    }
                  },
                  {
                    "row_id": 6,
                    "cells": {
                      "Rule": "Low usage alert",
                      "Condition": "Customer classified as low-usage",
                      "Action": "Send email + create Salesforce task",
                      "Notes": "SF task subject must contain customer name"
                    }
                  },
                  {
                    "row_id": 7,
                    "cells": {
                      "Rule": "No alert for non-low",
                      "Condition": "normal-usage or high-usage",
                      "Action": "Tag only, no email, no SF task",
                      "Notes": "Only low-usage triggers alerts"
                    }
                  }
                ]
              },
              {
                "id": "ws_onboarding_policy",
                "title": "Onboarding Policy",
                "headers": [
