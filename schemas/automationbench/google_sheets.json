{
  "$defs": {
    "Row": {
      "additionalProperties": false,
      "description": "Represents a single data row inside a Google Sheets worksheet.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "spreadsheet_id": {
          "title": "Spreadsheet Id",
          "type": "string"
        },
        "worksheet_id": {
          "title": "Worksheet Id",
          "type": "string"
        },
        "row_id": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "string"
            }
          ],
          "title": "Row Id"
        },
        "background_color": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Background Color"
        },
        "text_color": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Text Color"
        },
        "text_format_bold": {
          "default": false,
          "title": "Text Format Bold",
          "type": "boolean"
        },
        "text_format_italic": {
          "default": false,
          "title": "Text Format Italic",
          "type": "boolean"
        },
        "text_format_strikethrough": {
          "default": false,
          "title": "Text Format Strikethrough",
          "type": "boolean"
        },
        "timezone": {
          "default": false,
          "title": "Timezone",
          "type": "boolean"
        }
      },
      "required": [
        "spreadsheet_id",
        "worksheet_id",
        "row_id"
      ],
      "title": "Row",
      "type": "object"
    },
    "Spreadsheet": {
      "additionalProperties": false,
      "description": "Represents a top-level Google Sheets spreadsheet document.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "title": {
          "title": "Title",
          "type": "string"
        },
        "drive": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Drive"
        },
        "spreadsheet_to_copy": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Spreadsheet To Copy"
        },
        "headers": {
          "items": {
            "type": "string"
          },
          "title": "Headers",
          "type": "array"
        }
      },
      "required": [
        "title"
      ],
      "title": "Spreadsheet",
      "type": "object"
    },
    "Worksheet": {
      "additionalProperties": false,
      "description": "Represents a single sheet tab within a Google Sheets spreadsheet.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "spreadsheet_id": {
          "title": "Spreadsheet Id",
          "type": "string"
        },
        "title": {
          "title": "Title",
          "type": "string"
        },
        "headers": {
          "items": {
            "type": "string"
          },
          "title": "Headers",
          "type": "array"
        },
        "overwrite": {
          "default": false,
          "title": "Overwrite",
          "type": "boolean"
        },
        "copy_to": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Copy To"
        }
      },
      "required": [
        "spreadsheet_id",
        "title"
      ],
      "title": "Worksheet",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Top-level container for all Google Sheets state within a world.",
  "properties": {
    "spreadsheets": {
      "items": {
        "$ref": "#/$defs/Spreadsheet"
      },
      "title": "Spreadsheets",
      "type": "array"
    },
    "worksheets": {
      "items": {
        "$ref": "#/$defs/Worksheet"
      },
      "title": "Worksheets",
      "type": "array"
    },
    "rows": {
      "items": {
        "$ref": "#/$defs/Row"
      },
      "title": "Rows",
      "type": "array"
    }
  },
  "title": "GoogleSheetsState",
  "type": "object"
}
