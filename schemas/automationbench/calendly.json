{
  "$defs": {
    "EventType": {
      "additionalProperties": false,
      "description": "A Calendly event type that defines a scheduling template.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "uri": {
          "title": "Uri",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "slug": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Slug"
        },
        "duration": {
          "default": 30,
          "title": "Duration",
          "type": "integer"
        },
        "location_kind": {
          "anyOf": [
            {
              "enum": [
                "physical",
                "phone_call",
                "inbound_call",
                "outbound_call",
                "zoom_conference",
                "google_conference",
                "microsoft_teams_conference",
                "webex_conference",
                "goto_meeting_conference",
                "custom"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Location Kind"
        },
        "location": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Location"
        },
        "scheduling_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Scheduling Url"
        },
        "color": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Color"
        },
        "owner_id": {
          "default": "",
          "title": "Owner Id",
          "type": "string"
        },
        "owner_email": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
