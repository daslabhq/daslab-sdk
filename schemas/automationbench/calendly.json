        "is_active": {
          "default": true,
          "title": "Is Active",
          "type": "boolean"
        },
        "kind": {
          "default": "solo",
          "enum": [
            "solo",
            "group",
            "collective"
          ],
          "title": "Kind",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "title": "EventType",
      "type": "object"
    },
