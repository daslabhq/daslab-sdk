{
  "$defs": {
    "CanvaAsset": {
      "additionalProperties": false,
      "description": "A file asset that has been uploaded to Canva.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "file_type": {
          "default": "image/png",
          "title": "File Type",
          "type": "string"
        },
        "file_size": {
          "default": 0,
          "title": "File Size",
          "type": "integer"
        },
        "folder_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Folder Id"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "updated_at": {
          "format": "date-time",
          "title": "Updated At",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "title": "CanvaAsset",
      "type": "object"
    },
    "CanvaDesign": {
      "additionalProperties": false,
      "description": "A single design project in Canva.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "title": {
          "title": "Title",
          "type": "string"
        },
        "doctype_name": {
          "default": "Design",
          "title": "Doctype Name",
          "type": "string"
        },
        "design_type": {
          "default": "preset",
          "enum": [
            "preset",
            "custom"
          ],
          "title": "Design Type",
          "type": "string"
        },
        "owner": {
          "$ref": "#/$defs/CanvaOwner"
        },
        "thumbnail_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Thumbnail Url"
        },
        "edit_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Edit Url"
        },
        "view_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "View Url"
        },
        "folder_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Folder Id"
        },
        "tags": {
          "items": {
            "type": "string"
          },
          "title": "Tags",
          "type": "array"
        },
        "notes": {
          "default": "",
          "title": "Notes",
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "updated_at": {
          "format": "date-time",
          "title": "Updated At",
          "type": "string"
        }
      },
      "required": [
        "title"
      ],
      "title": "CanvaDesign",
      "type": "object"
    },
    "CanvaFolder": {
      "additionalProperties": false,
      "description": "A folder used to organize designs and assets in Canva.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "parent_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Parent Id"
        }
      },
      "required": [
        "id",
        "name"
      ],
      "title": "CanvaFolder",
      "type": "object"
    },
    "CanvaJob": {
      "additionalProperties": false,
      "description": "An asynchronous Canva operation such as an export, import, upload, or autofill.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "job_type": {
          "enum": [
            "export",
            "import",
            "upload",
            "autofill"
          ],
          "title": "Job Type",
          "type": "string"
        },
        "status": {
          "default": "IN_PROGRESS",
          "enum": [
            "IN_PROGRESS",
            "COMPLETED",
            "FAILED"
          ],
          "title": "Status",
          "type": "string"
        },
        "design_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Design Id"
        },
        "asset_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Asset Id"
        },
        "format_type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Format Type"
        },
        "result_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Result Url"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "updated_at": {
          "format": "date-time",
          "title": "Updated At",
          "type": "string"
        }
      },
      "required": [
        "job_type"
      ],
      "title": "CanvaJob",
      "type": "object"
    },
    "CanvaOwner": {
      "additionalProperties": false,
      "description": "Ownership metadata attached to a Canva design.",
      "properties": {
        "display_name": {
          "default": "User",
          "title": "Display Name",
          "type": "string"
        },
        "team_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Team Id"
        },
        "user_id": {
          "title": "User Id",
          "type": "string"
        }
      },
      "title": "CanvaOwner",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Overall Canva state holding designs, assets, jobs, and folders.",
  "properties": {
    "designs": {
      "items": {
        "$ref": "#/$defs/CanvaDesign"
      },
      "title": "Designs",
      "type": "array"
    },
    "assets": {
      "items": {
        "$ref": "#/$defs/CanvaAsset"
      },
      "title": "Assets",
      "type": "array"
    },
    "jobs": {
      "items": {
        "$ref": "#/$defs/CanvaJob"
      },
      "title": "Jobs",
      "type": "array"
    },
    "folders": {
      "items": {
        "$ref": "#/$defs/CanvaFolder"
      },
      "title": "Folders",
      "type": "array"
    }
  },
  "title": "CanvaState",
  "type": "object"
}
