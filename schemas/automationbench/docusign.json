          "title": "Voided Reason"
        },
        "declined_date_time": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Declined Date Time"
        },
        "status_changed_date_time": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Status Changed Date Time"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Internal notes or a brief summary for this envelope",
          "title": "Description"
        },
        "email_subject": {
          "default": "Please sign this document",
          "description": "Subject line used in the signing email",
          "title": "Email Subject",
          "type": "string"
        },
        "email_blurb": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Body text included in the signing email",
          "title": "Email Blurb"
        },
        "template_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "ID of the template this envelope was created from",
          "title": "Template Id"
        },
        "sender": {
          "anyOf": [
            {
              "$ref": "#/$defs/Sender"
            },
            {
              "type": "null"
            }
          ],
          "default": null
