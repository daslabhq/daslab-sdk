  "additionalProperties": false,
  "description": "Snapshot of DocuSign application data, grouping all object collections.",
  "properties": {
    "envelopes": {
      "items": {
        "$ref": "#/$defs/Envelope"
      },
      "title": "Envelopes",
      "type": "array"
    },
    "templates": {
      "items": {
        "$ref": "#/$defs/Template"
      },
      "title": "Templates",
      "type": "array"
    },
    "workspaces": {
      "items": {
        "$ref": "#/$defs/Workspace"
      },
      "title": "Workspaces",
      "type": "array"
    },
    "documents": {
      "items": {
        "additionalProperties": true,
        "type": "object"
      },
      "title": "Documents",
      "type": "array"
    },
    "recipients": {
      "items": {
        "additionalProperties": true,
        "type": "object"
      },
      "title": "Recipients",
      "type": "array"
    }
