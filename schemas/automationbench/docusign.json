            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Envelope identifier (mirrors the base id field)",
          "title": "Envelope Id"
        },
        "status": {
          "default": "created",
          "description": "Lifecycle status of the envelope: created, sent, delivered, completed, voided, or declined",
          "title": "Status",
          "type": "string"
