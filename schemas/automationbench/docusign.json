{
  "$defs": {
    "CarbonCopy": {
      "additionalProperties": false,
      "description": "A recipient who receives a copy of the envelope but is not required to sign.",
      "properties": {
        "recipient_id": {
          "description": "Unique identifier for this CC recipient",
          "title": "Recipient Id",
          "type": "string"
        },
        "name": {
          "description": "Full name of the CC recipient",
          "title": "Name",
          "type": "string"
        },
        "email": {
          "description": "Email address of the CC recipient",
          "title": "Email",
          "type": "string"
        },
        "routing_order": {
          "default": "1",
          "description": "Position in the delivery sequence",
          "title": "Routing Order",
          "type": "string"
        }
      },
      "required": [
        "recipient_id",
        "name",
        "email"
      ],
      "title": "CarbonCopy",
      "type": "object"
    },
    "Envelope": {
      "additionalProperties": false,
      "description": "DocuSign Envelope \u2014 the primary container holding documents and recipients.",
