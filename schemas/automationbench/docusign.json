        "signers": {
          "description": "Ordered list of signing recipients",
          "items": {
            "$ref": "#/$defs/Signer"
          },
          "title": "Signers",
          "type": "array"
        },
        "cc_recipients": {
          "description": "Recipients who receive a copy without signing",
          "items": {
            "$ref": "#/$defs/CarbonCopy"
          },
          "title": "Cc Recipients",
          "type": "array"
        },
        "custom_fields": {
          "additionalProperties": {
            "type": "string"
          },
          "description": "Pre-populated values for template fields",
          "title": "Custom Fields",
          "type": "object"
        },
        "documents": {
          "description": "Documents contained in this envelope",
          "items": {
            "$ref": "#/$defs/EnvelopeDocument"
          },
          "title": "Documents",
          "type": "array"
        },
        "uri": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Uri"
        },
        "certificate_uri": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Certificate Uri"
        },
        "templates_uri": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Templates Uri"
        },
        "is_signature_provider_envelope": {
          "default": false,
          "title": "Is Signature Provider Envelope",
          "type": "boolean"
        },
        "signer_can_sign_on_mobile": {
          "default": true,
          "title": "Signer Can Sign On Mobile",
          "type": "boolean"
        },
        "allow_comments": {
          "default": true,
          "title": "Allow Comments",
          "type": "boolean"
        },
        "allow_markup": {
          "default": true,
          "title": "Allow Markup",
          "type": "boolean"
        },
        "allow_view_history": {
          "default": true,
          "title": "Allow View History",
          "type": "boolean"
        }
      },
      "title": "Envelope",
      "type": "object"
    },
    "EnvelopeDocument": {
      "additionalProperties": false,
      "description": "Represents a single document attached to a DocuSign envelope.",
      "properties": {
        "document_id": {
          "description": "Unique identifier for this document",
          "title": "Document Id",
          "type": "string"
        },
        "name": {
          "description": "Display name of the document",
          "title": "Name",
          "type": "string"
        },
        "document_type": {
          "default": "content",
          "description": "Category of the document",
          "title": "Document Type",
          "type": "string"
        },
        "order": {
          "default": "1",
          "description": "Position of this document within the envelope",
          "title": "Order",
          "type": "string"
        },
        "pages": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Total page count for this document",
          "title": "Pages"
        }
      },
      "required": [
        "document_id",
        "name"
      ],
      "title": "EnvelopeDocument",
      "type": "object"
    },
    "Sender": {
      "additionalProperties": false,
      "description": "Identifies the person who sent a DocuSign envelope.",
      "properties": {
        "user_name": {
          "description": "Display name of the sender",
          "title": "User Name",
          "type": "string"
        },
        "user_id": {
          "description": "Internal user identifier for the sender",
          "title": "User Id",
          "type": "string"
        },
        "email": {
          "description": "Email address of the sender",
          "title": "Email",
          "type": "string"
        }
      },
      "required": [
        "user_name",
        "user_id",
        "email"
      ],
      "title": "Sender",
      "type": "object"
    },
    "Signer": {
      "additionalProperties": false,
      "description": "Represents a signing recipient attached to a DocuSign envelope.",
      "properties": {
        "recipient_id": {
          "description": "Unique identifier for this recipient",
          "title": "Recipient Id",
          "type": "string"
        },
        "name": {
          "description": "Full name of the signer",
          "title": "Name",
          "type": "string"
        },
        "email": {
          "description": "Email address of the signer",
          "title": "Email",
          "type": "string"
        },
        "status": {
          "default": "sent",
          "description": "Current recipient status \u2014 one of: sent, delivered, completed, declined",
          "title": "Status",
          "type": "string"
        },
        "routing_order": {
          "default": "1",
          "description": "Position of this signer in the signing sequence",
          "title": "Routing Order",
          "type": "string"
        },
        "role_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Role label assigned via a template",
          "title": "Role Name"
        }
      },
      "required": [
        "recipient_id",
        "name",
        "email"
      ],
      "title": "Signer",
      "type": "object"
    },
    "Template": {
      "additionalProperties": false,
