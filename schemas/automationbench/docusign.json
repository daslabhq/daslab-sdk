          "description": "Unique identifier for this DocuSign record",
          "title": "Id",
          "type": "string"
        },
        "created_date_time": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Created Date Time"
        },
        "last_modified_date_time": {
          "format": "date-time",
          "title": "Last Modified Date Time",
          "type": "string"
        },
        "envelope_id": {
          "anyOf": [
            {
              "type": "string"
