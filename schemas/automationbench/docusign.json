    "TemplateDocument": {
      "additionalProperties": false,
      "description": "A document that is bundled within a DocuSign template.",
      "properties": {
        "document_id": {
          "description": "Unique identifier for this document",
          "title": "Document Id",
          "type": "string"
        },
        "name": {
          "description": "Display name of the document",
          "title": "Name",
          "type": "string"
