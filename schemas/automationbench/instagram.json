            "IMAGE",
            "VIDEO",
            "CAROUSEL_ALBUM"
          ],
          "title": "Media Type",
          "type": "string"
        },
        "media_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Media Url"
        },
        "caption": {
          "default": "",
          "title": "Caption",
          "type": "string"
        },
        "permalink": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Permalink"
        },
        "shortcode": {
          "title": "Shortcode",
          "type": "string"
        },
        "tagged_users": {
          "items": {
            "type": "string"
          },
          "title": "Tagged Users",
          "type": "array"
        },
        "location": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
