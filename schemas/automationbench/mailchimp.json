{
  "$defs": {
    "MailchimpAudience": {
      "additionalProperties": false,
      "description": "Represents a single Mailchimp mailing list (audience).",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "web_id": {
          "title": "Web Id",
          "type": "string"
        },
        "permission_reminder": {
          "default": "You signed up for our newsletter.",
          "title": "Permission Reminder",
          "type": "string"
        },
        "contact_company": {
          "default": "",
          "title": "Contact Company",
          "type": "string"
        },
        "contact_address1": {
          "default": "",
          "title": "Contact Address1",
          "type": "string"
        },
        "contact_city": {
          "default": "",
          "title": "Contact City",
          "type": "string"
        },
        "contact_state": {
          "default": "",
          "title": "Contact State",
          "type": "string"
        },
        "contact_zip": {
          "default": "",
          "title": "Contact Zip",
          "type": "string"
        },
        "contact_country": {
          "default": "US",
          "title": "Contact Country",
          "type": "string"
        },
        "member_count": {
          "default": 0,
          "title": "Member Count",
          "type": "integer"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "title": "MailchimpAudience",
      "type": "object"
    },
    "MailchimpCampaign": {
      "additionalProperties": false,
      "description": "Represents a Mailchimp email campaign.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "web_id": {
          "title": "Web Id",
          "type": "string"
        },
        "list_id": {
          "title": "List Id",
          "type": "string"
        },
        "subject_line": {
          "title": "Subject Line",
          "type": "string"
        },
        "from_name": {
          "title": "From Name",
          "type": "string"
        },
        "reply_to": {
          "title": "Reply To",
          "type": "string"
        },
        "title": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Title"
        },
        "status": {
          "default": "save",
          "enum": [
            "save",
            "paused",
            "schedule",
            "sending",
            "sent"
          ],
          "title": "Status",
          "type": "string"
        },
        "campaign_type": {
          "default": "regular",
          "enum": [
            "regular",
            "plaintext",
            "absplit",
            "rss",
            "variate"
          ],
          "title": "Campaign Type",
          "type": "string"
        },
        "content_html": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Content Html"
        },
        "content_text": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Content Text"
        },
        "emails_sent": {
          "default": 0,
          "title": "Emails Sent",
          "type": "integer"
        },
        "send_time": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Send Time"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        }
      },
      "required": [
        "list_id",
        "subject_line",
        "from_name",
        "reply_to"
      ],
      "title": "MailchimpCampaign",
      "type": "object"
    },
    "MailchimpSubscriber": {
      "additionalProperties": false,
      "description": "Represents a single contact subscribed to a Mailchimp audience.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "email": {
          "title": "Email",
          "type": "string"
        },
        "list_id": {
          "title": "List Id",
          "type": "string"
        },
        "status": {
          "default": "subscribed",
          "enum": [
            "subscribed",
            "unsubscribed",
            "cleaned",
            "pending",
            "transactional",
            "archived"
          ],
          "title": "Status",
          "type": "string"
        },
        "email_type": {
          "default": "html",
          "enum": [
            "html",
            "text"
          ],
          "title": "Email Type",
          "type": "string"
        },
        "merge_fields": {
          "additionalProperties": true,
          "title": "Merge Fields",
          "type": "object"
        },
        "tags": {
          "items": {
            "type": "string"
          },
          "title": "Tags",
          "type": "array",
          "uniqueItems": true
        },
        "vip": {
          "default": false,
          "title": "Vip",
          "type": "boolean"
        },
        "source": {
          "default": "API",
          "title": "Source",
          "type": "string"
        },
        "notes": {
          "items": {
            "type": "string"
          },
          "title": "Notes",
          "type": "array"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "updated_at": {
          "format": "date-time",
          "title": "Updated At",
          "type": "string"
        },
        "last_open_days_ago": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Last Open Days Ago"
        },
        "open_rate": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Open Rate"
        }
      },
      "required": [
        "id",
        "email",
        "list_id"
      ],
      "title": "MailchimpSubscriber",
      "type": "object"
    },
    "MailchimpTag": {
      "additionalProperties": false,
      "description": "Represents a label that can be applied to audience members.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "list_id": {
          "title": "List Id",
          "type": "string"
        },
        "member_count": {
          "default": 0,
          "title": "Member Count",
          "type": "integer"
        }
      },
      "required": [
        "name",
        "list_id"
      ],
      "title": "MailchimpTag",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Top-level container holding all Mailchimp audiences, subscribers, campaigns, and tags.",
  "properties": {
    "audiences": {
      "items": {
        "$ref": "#/$defs/MailchimpAudience"
      },
      "title": "Audiences",
      "type": "array"
    },
    "subscribers": {
      "items": {
        "$ref": "#/$defs/MailchimpSubscriber"
      },
      "title": "Subscribers",
      "type": "array"
    },
    "campaigns": {
      "items": {
        "$ref": "#/$defs/MailchimpCampaign"
      },
      "title": "Campaigns",
      "type": "array"
    },
    "tags": {
      "items": {
        "$ref": "#/$defs/MailchimpTag"
      },
      "title": "Tags",
      "type": "array"
    }
  },
  "title": "MailchimpState",
  "type": "object"
}
