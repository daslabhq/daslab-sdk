{
  "$defs": {
    "ReamazeContact": {
      "additionalProperties": false,
      "description": "Represents a customer or contact record stored in Re:amaze.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Name"
        },
        "email": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Email"
        },
        "phone": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Phone"
        },
        "notes": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Notes"
        },
        "external_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "External Id"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "updated_at": {
          "format": "date-time",
          "title": "Updated At",
          "type": "string"
        }
      },
      "title": "ReamazeContact",
      "type": "object"
    },
    "ReamazeConversation": {
      "additionalProperties": false,
      "description": "Represents a support conversation tracked in Re:amaze.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "subject": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Subject"
        },
        "status": {
          "default": "unresolved",
          "enum": [
            "unresolved",
            "resolved",
            "archived",
            "pending"
          ],
          "title": "Status",
          "type": "string"
        },
        "category": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Category"
        },
        "brand": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Brand"
        },
        "contact_email": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Contact Email"
        },
        "contact_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Contact Name"
        },
        "assignee_email": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Assignee Email"
        },
        "messages": {
          "items": {
            "$ref": "#/$defs/ReamazeMessage"
          },
          "title": "Messages",
          "type": "array"
        },
        "tags": {
          "items": {
            "type": "string"
          },
          "title": "Tags",
          "type": "array"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "updated_at": {
          "format": "date-time",
          "title": "Updated At",
          "type": "string"
        }
      },
      "title": "ReamazeConversation",
      "type": "object"
    },
    "ReamazeMessage": {
      "additionalProperties": false,
      "description": "Represents a single message within a Re:amaze conversation thread.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "body": {
          "title": "Body",
          "type": "string"
        },
        "author_type": {
          "default": "customer",
          "enum": [
            "customer",
            "staff"
          ],
          "title": "Author Type",
          "type": "string"
        },
        "author_email": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Author Email"
        },
        "author_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Author Name"
        },
        "visibility": {
          "default": "regular",
          "enum": [
            "regular",
            "internal"
          ],
          "title": "Visibility",
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        }
      },
      "required": [
        "body"
      ],
      "title": "ReamazeMessage",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Top-level container holding all Re:amaze conversations and contacts.",
  "properties": {
    "conversations": {
      "items": {
        "$ref": "#/$defs/ReamazeConversation"
      },
      "title": "Conversations",
      "type": "array"
    },
    "contacts": {
      "items": {
        "$ref": "#/$defs/ReamazeContact"
      },
      "title": "Contacts",
      "type": "array"
    }
  },
  "title": "ReamazeState",
  "type": "object"
}
