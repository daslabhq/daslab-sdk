{
  "$defs": {
    "PipefyActionRecord": {
      "additionalProperties": false,
      "description": "Represents a single recorded action performed via the Pipefy CLI.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "action_key": {
          "title": "Action Key",
          "type": "string"
        },
        "params": {
          "additionalProperties": true,
          "title": "Params",
          "type": "object"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        }
      },
      "required": [
        "action_key"
      ],
      "title": "PipefyActionRecord",
      "type": "object"
    },
    "PipefyCard": {
      "additionalProperties": false,
      "description": "Represents a card within a Pipefy pipe.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "title": {
          "title": "Title",
          "type": "string"
        },
        "phase": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Phase"
        },
        "phase_changed": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Phase Changed"
        },
        "pipe_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Pipe Id"
        },
        "opportunity_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Opportunity Id"
        },
        "amount": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Amount"
        },
        "assignee_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Assignee Id"
        },
        "labels": {
          "items": {
            "type": "string"
          },
          "title": "Labels",
          "type": "array"
        },
        "fields": {
          "additionalProperties": true,
          "title": "Fields",
          "type": "object"
        }
      },
      "required": [
        "id",
        "title"
      ],
      "title": "PipefyCard",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Holds the accumulated state of all actions and cards in Pipefy.",
  "properties": {
    "actions": {
      "additionalProperties": {
        "items": {
          "$ref": "#/$defs/PipefyActionRecord"
        },
        "type": "array"
      },
      "title": "Actions",
      "type": "object"
    },
    "cards": {
      "items": {
        "$ref": "#/$defs/PipefyCard"
      },
      "title": "Cards",
      "type": "array"
    }
  },
  "title": "PipefyState",
  "type": "object"
}
