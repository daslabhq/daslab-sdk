        "sid": {
          "title": "Sid",
          "type": "string"
        },
        "account_sid": {
          "title": "Account Sid",
          "type": "string"
        },
        "from_number": {
          "title": "From Number",
          "type": "string"
        },
        "to_number": {
          "title": "To Number",
          "type": "string"
        },
        "body": {
          "title": "Body",
          "type": "string"
