          "title": "Status",
          "type": "string"
        },
        "direction": {
          "default": "outbound-api",
          "title": "Direction",
          "type": "string"
        },
        "date_created": {
          "format": "date-time",
          "title": "Date Created",
          "type": "string"
        },
        "date_updated": {
          "format": "date-time",
          "title": "Date Updated",
          "type": "string"
        },
        "num_segments": {
          "default": 1,
          "title": "Num Segments",
          "type": "integer"
        }
      },
      "required": [
        "from_number",
        "to_number",
        "body"
      ],
      "title": "WhatsAppMessage",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Top-level container holding all Twilio SMS messages, WhatsApp messages, and calls.",
  "properties": {
    "sms_messages": {
